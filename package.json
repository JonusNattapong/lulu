{
  "name": "luluai",
  "version": "0.0.7",
  "license": "MIT",
  "description": "A small personal AI assistant for working with local files.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lulu": "dist/index.js",
    "lulu-telegram": "dist/integrations/telegram.js"
  },
  "files": [
    "dist",
    ".env.example",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "desktop": "node scripts/desktop.mjs",
    "desktop:dev": "node scripts/desktop.mjs",
    "desktop:app": "electron desktop/main.cjs",
    "desktop:build": "node scripts/build-desktop.mjs",
    "desktop:pack": "npm run desktop:build && electron-builder --dir",
    "desktop:dist": "npm run desktop:build && electron-builder",
    "desktop:icons": "node desktop/generate-icons.cjs",
    "dev": "bun src/cli/index.tsx",
    "start": "bun dist/cli/index.js",
    "lulu": "bun src/cli/index.tsx",
    "server": "bun src/api/server.ts",
    "telegram": "bun src/integrations/telegram.ts",
    "telegram:setup": "bun src/integrations/telegram.ts setup",
    "onboard": "bun src/core/onboarding.ts",
    "heartbeat": "bun src/core/heartbeat.ts",
    "heartbeat:once": "bun src/core/heartbeat.ts --once",
    "daemon": "bun src/core/daemon.ts",
    "daemon:start": "bun src/core/daemon.ts start",
    "daemon:stop": "bun src/core/daemon.ts stop",
    "daemon:status": "bun src/core/daemon.ts status",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "build": {
    "appId": "com.luluai.desktop",
    "productName": "Lulu",
    "directories": {
      "output": "release",
      "buildResources": "desktop"
    },
    "files": [
      "dist/**/*",
      "dashboard/dist/**/*",
      "desktop/**/*",
      "!desktop/**/*.cjs",
      "!desktop/node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "desktop/main.cjs"
    },
    "win": {
      "target": ["nsis"],
      "icon": "desktop/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "desktop/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "desktop/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "JonusNattapong",
      "repo": "lulu"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/static": "^1.4.10",
    "@elysiajs/swagger": "^1.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.9.0",
    "elysia": "^1.4.28",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^18.0.3",
    "open": "^11.0.0",
    "picocolors": "^1.1.1",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "sqlite-vec": "^0.1.9",
    "sqlite3": "^6.0.1",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.13",
    "@types/marked": "^6.0.0",
    "@types/node": "^22.0.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
