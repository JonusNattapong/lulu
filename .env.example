# Lulu Configuration
# Copy this to .env or set in ~/.lulu/config.json

# Primary Provider (claude, openai, google, kilocode, etc.)
LULU_PROVIDER=claude
LULU_MODEL=claude-3-5-sonnet-20241022

# API Keys (Set these or use ~/.lulu/config.json)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
KILOCODE_API_KEY=
DEEPSEEK_API_KEY=

# Permissions
LULU_ALLOW_WRITE=false
LULU_ALLOW_COMMAND=false
LULU_ALLOW_TMUX=false

# Agent Settings
LULU_MAX_TOKENS=4096
LULU_SYSTEM_PROMPT=
LULU_PROMPT_PROFILE=default
LULU_SESSION_MAX_MESSAGES=24
LULU_SKILL_LIMIT=5
LULU_HEARTBEAT_INTERVAL_MS=60000

# Telegram Bridge
LULU_TELEGRAM_BOT_TOKEN=
LULU_TELEGRAM_ALLOWED_CHAT_IDS=
