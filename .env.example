# Choose your provider (default: claude)
LULU_PROVIDER=claude

# Provider API keys (set at least one)
ANTHROPIC_API_KEY=your_api_key
# OPENAI_API_KEY=your_api_key
# DEEPSEEK_API_KEY=your_api_key
# OPENROUTER_API_KEY=your_api_key
# MISTRAL_API_KEY=your_api_key
# GOOGLE_API_KEY=your_api_key
# KILOCODE_API_KEY=your_api_key
# OPENCODE_API_KEY=your_api_key
# CLINE_API_KEY=your_api_key
# COPILOT_API_KEY=your_api_key

# Optional overrides
LULU_MODEL=claude-3-5-sonnet-20241022
LULU_MAX_TOKENS=4096
LULU_ALLOW_WRITE=false
LULU_ALLOW_COMMAND=false
